        "sendTo": "angch@tertiaryinfotech.com",
        "subject": "=Leave approval needed: {{ $('Leave Submitted').item.json.body.employee }}",
        "message": "=Employee: {{ $('Leave Submitted').item.json.body.employee }}\nEmail: {{ $('Leave Submitted').item.json.body.email }}\nType: {{ $('Leave Submitted').item.json.body.leaveType }}\nDates: {{ $('Leave Submitted').item.json.body.startDate }} to {{ $('Leave Submitted').item.json.body.endDate }} ({{ $('Leave Submitted').item.json.body.days }} day(s))\nReason: {{ $('Leave Submitted').item.json.body.reason }}\n\nPlease approve or decline this leave request.",
        "options": {},
        "operation": "sendAndWait",
        "approvalOptions": {
          "values": {
            "approvalType": "double"
          }
        }
      },
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.2,
      "position": [
        480,
        0
      ],
